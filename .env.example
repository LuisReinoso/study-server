# Study Server - environment configuration
#
# Copy this file to `.env` and adjust for your setup.
# `.env` is gitignored so nothing here gets committed by accident.

# Port the HTTP server listens on.
STUDY_SERVER_PORT=3457

# Host/interface to bind to. 0.0.0.0 exposes the server to your whole
# network (needed to reach it from Obsidian mobile); use 127.0.0.1 to
# restrict it to localhost only.
BIND_HOST=0.0.0.0

# Comma-separated list of OpenAI-compatible base URLs to try, in order.
# The server probes GET {url}/models on each and uses the first one that
# responds with 200, caching that choice for 60s. This is meant for a setup
# with several llama.cpp servers (started/stopped on demand) plus an Ollama
# instance as a fallback (Ollama also exposes an OpenAI-compatible API under
# /v1). Only some of these need to be up at any given time.
LLM_ENDPOINTS=http://127.0.0.1:8898/v1,http://127.0.0.1:8899/v1,http://127.0.0.1:8897/v1,http://127.0.0.1:11434/v1

# OPTIONAL: force a specific model name in every chat completion request.
# If unset, the server auto-selects the first CHAT-capable model id reported
# by whichever endpoint /models returned 200 (llama.cpp reports its currently
# loaded model there; Ollama reports every model it has pulled, so the server
# skips ids that look like embedding/rerank models - containing "embed",
# "bge", or "rerank" - before picking one). Pin LLM_MODEL if you route
# through Ollama and want a specific chat model other than the first one.
# LLM_MODEL=

# OPTIONAL: require every /api/* request (except /api/health) to send
# `Authorization: Bearer <this value>`. Leave unset to disable auth, which is
# fine on a trusted LAN/Tailscale network but not if the server is reachable
# from anywhere less trusted.
# STUDY_SERVER_TOKEN=
